programa {
  funcao inicio() {
    inteiro lua, grau, a, b, c
    escreva("Qual é o grau da lua A?:")
    leia(grau)
    escreva("Qual é o grau da lua B?:")
    leia(grau)
    escreva("Qual é o grau da lua C?:")
    leia(grau)

    se (a == b e b == c){
  escreva("Eclipse Total")
    }
    senao se (a == b ou b == c){
      escreva("Parcial")
    }
    senao{
      escreva("Dispersão")
    }
  }
}