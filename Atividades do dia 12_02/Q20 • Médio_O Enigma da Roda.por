programa {
  funcao inicio() {
    inteiro n1, n2, n3, n4, outro_numero, tumba
    escreva("Qual número de tumba você escolhe?:")
    leia(tumba)
    escolha(tumba){
  caso 1: 
  escreva("Fogo")
  pare

  caso 2:
  escreva("Água")
  pare

  caso 3:
  escreva("Terra")
  pare

  caso 4:
  escreva("Ar")
  pare

  caso contrario:
  escreva("Armadilha")
    }
    
  }
}